stage       = "dev"
servicename = "myapp"

tags = {
  Environment = "dev"
  Owner       = "myteam"
  ManagedBy   = "terraform"
}

key_name_seoul = "your-seoul-keypair-name"
key_name_tokyo = "your-tokyo-keypair-name"

app_instance_type = "t3.small"
app_ami_seoul     = "ami-xxxxxxxxxxxxxxxxx"  # 서울 리전 앱 서버 AMI ID
app_ami_tokyo     = "ami-xxxxxxxxxxxxxxxxx"  # 도쿄 리전 앱 서버 AMI ID

vpn_ami_seoul     = "ami-xxxxxxxxxxxxxxxxx"  # 서울 리전 VPN AMI ID (OpenVPN AS)
vpn_ami_tokyo     = "ami-xxxxxxxxxxxxxxxxx"  # 도쿄 리전 VPN AMI ID (OpenVPN AS)
vpn_instance_type = "t3.small"

rk_instance_type = "t3.medium"

database_name     = "your_db_name"
db_username       = "admin"
db_password       = ""  # 환경변수로 주입 권장: export TF_VAR_db_password="..."
db_instance_class = "db.r6g.large"

domain_name    = "your-domain.com"
hosted_zone_id = ""  # Route53 Hosted Zone ID (AWS 콘솔에서 확인)

acm_arn_seoul = ""  # arn:aws:acm:ap-northeast-2:<account-id>:certificate/<uuid>
acm_arn_tokyo = ""  # arn:aws:acm:ap-northeast-1:<account-id>:certificate/<uuid>

alert_email = "your-email@example.com"

secondary_cluster_id = "aws-dev-myapp-secondary"  # Aurora DR 보조 클러스터 ID
